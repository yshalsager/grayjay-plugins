{
  "name": "Mixlr",
  "description": "Browse public Mixlr live audio channels and events.",
  "author": "yshalsager",
  "authorUrl": "https://github.com/yshalsager",
  "platformUrl": "https://mixlr.com",
  "sourceUrl": "https://raw.githubusercontent.com/yshalsager/grayjay-plugins/master/plugins/mixlr/MixlrConfig.json",
  "repositoryUrl": "https://github.com/yshalsager/grayjay-plugins",
  "scriptUrl": "./MixlrScript.js",
  "version": 1,
  "iconUrl": "https://mixlr.com/favicon.ico",
  "id": "62c60a1f-99e5-4b60-81e6-5ea04f923b6c",
  "packages": ["Http"],
  "allowEval": false,
  "allowUrls": ["mixlr.com", ".mixlr.com", "apicdn.mixlr.com", "api.mixlr.com", "listen.mixlr.com", "imagescdn.mixlr.com"],
  "settings": [
    {
      "variable": "homeMode",
      "name": "Home Page",
      "description": "Choose what Mixlr home shows.",
      "type": "Dropdown",
      "default": "0",
      "options": ["Popular live", "Category live", "Search live"]
    },
    {
      "variable": "homeCategory",
      "name": "Home Category",
      "description": "Category used when Home Page is set to Category live.",
      "type": "Dropdown",
      "default": "0",
      "options": ["Popular", "Religion", "Talk", "Culture", "Eclectic", "Sports", "Uncategorized"]
    }
  ],
  "changelog": {
    "1": [
      "Initial Mixlr public live audio plugin with popular/category/search live feeds, channel search, direct channel/event URL handling, live MP3 playback, channel peeks, and recommendations."
    ]
  },
  "scriptPublicKey": "",
  "scriptSignature": ""
}
