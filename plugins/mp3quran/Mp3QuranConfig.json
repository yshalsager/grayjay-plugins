{
  "name": "MP3Quran",
  "description": "Browse MP3Quran.net reciters, moshaf playlists, surah audio tracks with ayah chapters/subtitles, tafsir playlists/audio, reminder video playlists, recent reads, live Quran radio streams, and live TV.",
  "author": "yshalsager",
  "authorUrl": "https://github.com/yshalsager",
  "platformUrl": "https://mp3quran.net",
  "sourceUrl": "https://raw.githubusercontent.com/yshalsager/grayjay-plugins/master/plugins/mp3quran/Mp3QuranConfig.json",
  "repositoryUrl": "https://github.com/yshalsager/grayjay-plugins",
  "scriptUrl": "./Mp3QuranScript.js",
  "version": 1,
  "iconUrl": "./Mp3QuranIcon.png",
  "id": "6f5406d8-0e8d-4a81-85ee-554c89d9f460",
  "scriptSignature": "",
  "scriptPublicKey": "",
  "packages": ["Http"],
  "allowEval": false,
  "allowUrls": [
    "mp3quran.net",
    ".mp3quran.net",
    "qurango.net",
    ".qurango.net",
    "stream.radiojar.com",
    "win.holol.com",
    "upload.mp3quran.net",
    "server17.mp3quran.net",
    "cdn.jsdelivr.net",
    ".jsdelivr.net"
  ],
  "settings": [
    {
      "variable": "language",
      "name": "Catalog Language",
      "description": "Language used for reciter, surah, and radio names.",
      "type": "Dropdown",
      "default": "0",
      "options": [
        "Arabic",
        "English",
        "French",
        "Russian",
        "German",
        "Spanish",
        "Turkish",
        "Chinese",
        "Thai",
        "Urdu",
        "Bengali",
        "Bosnian",
        "Uyghur",
        "Persian",
        "Tajik (Cyrillic)",
        "Malayalam",
        "Tagalog",
        "Indonesian",
        "Portuguese",
        "Hausa",
        "Swahili"
      ]
    },
    {
      "variable": "homeMode",
      "name": "Home Page",
      "description": "Choose what the home tab shows.",
      "type": "Dropdown",
      "default": "0",
      "options": ["Live radios", "Complete recitations", "Live TV", "Recent reads", "Tafsir audio", "Videos"]
    }
  ],
  "changelog": {
    "1": [
      "Initial MP3Quran reciters, moshaf playlists, tracks, ayah chapters/subtitles, tafsir playlists/audio, video-type playlists/videos, recent reads, live radio, live TV, reciter/search filters, channels, channel peeks, richer suggestions, localized labels, thumbnails, and recommendations."
    ]
  }
}
