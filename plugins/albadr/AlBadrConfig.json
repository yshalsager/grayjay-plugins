{
  "name": "البدر",
  "description": "دروس الشيخ عبد الرزاق البدر الصوتية والبث المباشر عبر Mixlr.",
  "author": "yshalsager",
  "authorUrl": "https://github.com/yshalsager",
  "platformUrl": "https://www.al-badr.net",
