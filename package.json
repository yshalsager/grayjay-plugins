  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "build:all": "node scripts/build.mjs --plugin all",
    "scaffold": "node scripts/scaffold-plugin.mjs",
    "validate": "node scripts/validate.mjs",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:live": "vitest run tests/live",
    "test:live:mp3quran": "vitest run tests/live/mp3quran.live.test.js",
    "test:live:tvquran": "vitest run tests/live/tvquran.live.test.js",
    "test:live:archiveorg": "vitest run tests/live/archiveorg.live.test.js",
    "test:live:mixlr": "vitest run tests/live/mixlr.live.test.js",
    "test:live:albadr": "vitest run tests/live/albadr.live.test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "pnpm run format:check && pnpm run lint && pnpm run build:all && pnpm run validate && pnpm run test",
    "bump": "zx scripts/bump-and-sign.mjs bump",
    "sign": "zx scripts/bump-and-sign.mjs sign",
    "sign-bump": "zx scripts/bump-and-sign.mjs sign-bump"
  },
  "devDependencies": {
    "@clack/prompts": "1.4.0",
    "@eslint/js": "10.0.1",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "zx": "8.8.5"
